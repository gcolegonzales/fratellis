# Copy to .env for local dev. All PUBLIC_ vars are exposed to the client bundle.

# Formspree form id (e.g. "abcdwxyz" from https://formspree.io/f/abcdwxyz).
# When unset, reservation/catering forms fall back to a mailto: link.
PUBLIC_FORMSPREE_ID=

# GitHub Pages base path (set by CI from the repo name, e.g. /fratellis/).
# Leave unset for local dev (defaults to /).
# BASE_PATH=/fratellis/
