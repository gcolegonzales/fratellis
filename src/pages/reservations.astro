---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ReservationForm from '../components/ReservationForm.astro';
import { site } from '../lib/site';
---

<BaseLayout
  title="Reservations"
  description={`Request a table at ${site.name} in Prairieville. We'll confirm by phone.`}
>
  <Section>
    <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr]">
      <div class="max-w-prose">
        <p class="eyebrow">Join us</p>
        <h1 class="mt-3">Reserve a table</h1>
        <p class="prose-warm mt-4">
          Tell us when you're coming and how many, and we'll take care of the rest. Reservations are
          a request — we'll follow up by phone to confirm.
        </p>
        <p class="prose-warm mt-4">
          Prefer to talk? Call us at
          <a href={`tel:${site.phoneHref}`} class="font-semibold text-terracotta-700">{site.phone}</a
          >. We're closed Mondays.
        </p>
      </div>

      <div class="rounded-card bg-cream-50 p-6 shadow-soft ring-1 ring-charcoal/10 sm:p-8">
        <ReservationForm />
      </div>
    </div>
  </Section>
</BaseLayout>
