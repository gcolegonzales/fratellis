---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Gallery, { type GalleryImage } from '../components/Gallery.astro';

// Placeholder imagery — replace the files in public/images/gallery/ with real
// photos (keep the same filenames or update this list). See the README there.
const images: GalleryImage[] = [
  { src: '/images/gallery/dining-room.jpg', alt: 'A candlelit table set with gold-rimmed china at Fratelli’s' },
  { src: '/images/gallery/pizza.jpg', alt: 'A thin-crust Margherita pizza with fresh basil' },
  { src: '/images/gallery/pasta.jpg', alt: 'A bowl of house-made pasta finished with shaved Parmesan' },
  { src: '/images/gallery/bar.jpg', alt: 'Wine glasses glowing in warm candlelight' },
  { src: '/images/gallery/tiramisu.jpg', alt: 'Classic Italian tiramisu dusted with cocoa' },
  { src: '/images/gallery/table.jpg', alt: 'An al fresco table with wine, bread, and olives' },
];
---

<BaseLayout
  title="Gallery"
  description="A look inside Fratelli's Italian Grille — the dining room, the food, and the family table."
>
  <Section>
    <div class="max-w-prose">
      <p class="eyebrow">A look inside</p>
      <h1 class="mt-3">Gallery</h1>
      <p class="prose-warm mt-4">
        A taste of the room and the table. Tap any photo to view it larger.
      </p>
    </div>

    <div class="mt-10">
      <Gallery images={images} />
    </div>
  </Section>
</BaseLayout>
