---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import HoursTable from '../components/HoursTable.astro';
import OpenNowBadge from '../components/OpenNowBadge.astro';
import Testimonials from '../components/Testimonials.astro';
import { withBase } from '../lib/base';
import { site, formatAddress, directionsUrl } from '../lib/site';
---

<BaseLayout>
  <Hero />

  <!-- Ambiance / story — mood first, not menu -->
  <Section tone="white">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="max-w-prose" data-reveal>
        <p class="eyebrow">Benvenuti</p>
        <h2 class="mt-2">A little corner of Italy in Prairieville</h2>
        <p class="prose-warm mt-5">
          Since {site.established}, Fratelli's has been a family-owned kitchen where the sauce
          simmers all day and every plate is made to order. Step in and you're greeted by the aroma
          of garlic and fresh basil — and treated like part of the family.
        </p>
        <p class="prose-warm mt-4">
          It's the kind of place you come for a quiet dinner and leave already planning your next
          visit.
        </p>
        <div class="mt-8">
          <Button href={withBase('/about')} variant="ghost">Our story</Button>
        </div>
      </div>
      <figure class="overflow-hidden rounded-card shadow-soft ring-1 ring-charcoal/10" data-reveal>
        <img
          src={withBase('/images/gallery/entree.jpg')}
          alt="Grilled lamb chops over creamy risotto at Fratelli's"
          width="1200"
          height="900"
          class="aspect-[4/3] h-full w-full object-cover"
        />
      </figure>
    </div>
  </Section>

  <!-- Understated invitation to the menu (no dish catalog on the home page) -->
  <Section tone="charcoal" innerClass="text-center" reveal={false}>
    <div data-reveal>
      <p class="eyebrow text-gold-400">On the table tonight</p>
      <h2 class="mt-2 text-cream-50">Fresh pasta, wood-fired pizza, and Italian classics</h2>
      <p class="mx-auto mt-4 max-w-prose text-cream-100/85">
        From hand-filled ravioli to veal marsala and a wine list to match. Come hungry.
      </p>
      <div class="mt-7 flex justify-center gap-3">
        <Button href={withBase('/menu')} class="bg-cream-50 text-charcoal hover:bg-cream-100"
          >Explore the menu →</Button
        >
        <Button
          href={withBase('/from-the-bar')}
          variant="ghost"
          class="text-cream-50 ring-cream-100/40 hover:bg-cream-50/10">From the bar</Button
        >
      </div>
    </div>
  </Section>

  <!-- Plan your visit -->
  <Section>
    <div class="grid gap-8 rounded-card bg-cream-50 p-8 shadow-soft ring-1 ring-charcoal/10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Plan your visit</p>
        <h2 class="mt-2 text-2xl">We'd love to have you</h2>
        <div class="mt-4"><OpenNowBadge /></div>
        <address class="prose-warm mt-4 not-italic">{formatAddress()}</address>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={withBase('/reservations')} variant="primary">Reserve a table</Button>
          <Button href={directionsUrl()} variant="ghost">Get directions</Button>
        </div>
      </div>
      <div>
        <h3 class="text-lg">Hours</h3>
        <div class="mt-3 max-w-sm"><HoursTable /></div>
      </div>
    </div>
  </Section>

  <!-- Quiet social proof -->
  <Section tone="white">
    <div class="mx-auto max-w-prose text-center" data-reveal>
      <p class="eyebrow">Kind words</p>
      <h2 class="mt-2">Loved by the neighborhood</h2>
    </div>
    <div class="mt-8">
      <Testimonials limit={2} columns={2} />
    </div>
    <div class="mt-8 text-center" data-reveal>
      <Button href={withBase('/testimonials')} variant="ghost">Read more reviews</Button>
    </div>
  </Section>

  <!-- Catering invitation -->
  <Section tone="olive" innerClass="text-center" reveal={false}>
    <div data-reveal>
      <h2 class="text-cream-50">Planning an event?</h2>
      <p class="mx-auto mt-3 max-w-prose text-cream-100/90">
        From office lunches to family celebrations, let Fratelli's cater your next gathering.
      </p>
      <div class="mt-6 flex justify-center">
        <Button href={withBase('/catering')} class="bg-cream-50 text-charcoal hover:bg-cream-100"
          >Catering inquiry</Button
        >
      </div>
    </div>
  </Section>
</BaseLayout>
