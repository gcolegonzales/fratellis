---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import DishCard from '../components/DishCard.astro';
import HoursTable from '../components/HoursTable.astro';
import OpenNowBadge from '../components/OpenNowBadge.astro';
import Testimonials from '../components/Testimonials.astro';
import { withBase } from '../lib/base';
import { site, formatAddress, directionsUrl } from '../lib/site';
import type { MenuItem } from '../lib/menu';

const food = await getEntry('menu', 'food');
const featured = (food.data.items as MenuItem[]).filter((i) => i.featured).slice(0, 4);
---

<BaseLayout>
  <Hero />

  <!-- Signature dishes -->
  <Section tone="white">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-prose">
        <p class="eyebrow">Guest favorites</p>
        <h2 class="mt-2">Signature dishes</h2>
        <p class="prose-warm mt-3">A few of the plates our regulars can't stop ordering.</p>
      </div>
      <Button href={withBase('/menu')} variant="ghost">See the full menu</Button>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {featured.map((item) => <DishCard item={item} />)}
    </div>
  </Section>

  <!-- Hours & location strip -->
  <Section>
    <div class="grid gap-8 rounded-card bg-cream-50 p-8 shadow-soft ring-1 ring-charcoal/10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Visit us</p>
        <h2 class="mt-2 text-2xl">Come hungry</h2>
        <div class="mt-4"><OpenNowBadge /></div>
        <address class="prose-warm mt-4 not-italic">{formatAddress()}</address>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={`tel:${site.phoneHref}`} variant="primary">Call {site.phone}</Button>
          <Button href={directionsUrl()} variant="ghost">Get directions</Button>
        </div>
      </div>
      <div>
        <h3 class="text-lg">Hours</h3>
        <div class="mt-3 max-w-sm"><HoursTable /></div>
      </div>
    </div>
  </Section>

  <!-- Social proof -->
  <Section tone="white">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-prose">
        <p class="eyebrow">Kind words</p>
        <h2 class="mt-2">Loved by the neighborhood</h2>
      </div>
      <Button href={withBase('/testimonials')} variant="ghost">Read more reviews</Button>
    </div>
    <div class="mt-8">
      <Testimonials limit={3} />
    </div>
  </Section>

  <!-- Catering teaser -->
  <Section tone="olive" innerClass="text-center">
    <h2 class="text-cream-50">Planning an event?</h2>
    <p class="mx-auto mt-3 max-w-prose text-cream-100/90">
      From office lunches to family celebrations, let Fratelli's cater your next gathering.
    </p>
    <div class="mt-6 flex justify-center gap-3">
      <Button href={withBase('/catering')} class="bg-cream-50 text-charcoal hover:bg-cream-100">
        Catering inquiry
      </Button>
      <Button href={withBase('/reservations')} variant="ghost" class="text-cream-50 ring-cream-100/40 hover:bg-cream-50/10">
        Reserve a table
      </Button>
    </div>
  </Section>
</BaseLayout>
