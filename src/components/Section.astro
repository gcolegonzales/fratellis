---
// Layout primitive: consistent max-width, horizontal padding, and vertical rhythm.
interface Props {
  as?: string;
  id?: string;
  width?: 'content' | 'prose' | 'full';
  tone?: 'cream' | 'white' | 'olive' | 'charcoal';
  class?: string;
  innerClass?: string;
  reveal?: boolean;
}

const {
  as: Tag = 'section',
  id,
  width = 'content',
  tone = 'cream',
  class: className = '',
  innerClass = '',
  reveal = true,
} = Astro.props;

const tones = {
  cream: '',
  white: 'bg-cream-50',
  olive: 'bg-olive-700 text-cream-100',
  charcoal: 'bg-charcoal text-cream-100',
};

const widths = {
  content: 'max-w-content',
  prose: 'max-w-prose',
  full: 'max-w-none',
};

const outer = ['py-14 sm:py-20', tones[tone as keyof typeof tones], className].join(' ');
const inner = ['mx-auto px-5 sm:px-8', widths[width as keyof typeof widths], innerClass].join(' ');
---

<Tag id={id} class={outer}>
  <div class={inner} data-reveal={reveal ? '' : undefined}>
    <slot />
  </div>
</Tag>
