---
import { formatVariants, type MenuItem } from '../lib/menu';

interface Props {
  item: MenuItem;
}
const { item } = Astro.props;
const prices = formatVariants(item);
const tags = item.tags ?? [];
// data-search powers the client text filter; keep it lowercase.
const search = `${item.name} ${item.description ?? ''}`.toLowerCase();
---

<article
  class:list={[
    'dish-card flex flex-col rounded-card bg-cream-50 p-5 shadow-soft ring-1 ring-charcoal/5 transition',
    item.featured && 'ring-gold-400/60',
  ]}
  data-dish-id={item.id}
  data-category={item.category}
  data-tags={tags.join(' ')}
  data-search={search}
>
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="font-display text-lg font-semibold leading-snug text-charcoal">
      {item.name}
      {item.featured && <span class="ml-1 align-middle text-gold-500" aria-label="House favorite" title="House favorite">★</span>}
    </h3>
    <p class="shrink-0 text-right font-body text-sm font-semibold text-terracotta-700">
      {prices.join(' · ')}
      {item.marketPrice && <span class="block text-xs font-normal text-charcoal-muted">Market price</span>}
    </p>
  </div>

  {item.description && <p class="prose-warm mt-2 text-sm">{item.description}</p>}

  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((t) => (
          <li class="rounded-pill bg-olive-100 px-2 py-0.5 text-[0.7rem] font-medium capitalize text-olive-700">
            {t.replace(/-/g, ' ')}
          </li>
        ))}
      </ul>
    )
  }
</article>
