---
import { site, mapEmbedUrl } from '../lib/site';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['overflow-hidden rounded-card shadow-soft ring-1 ring-charcoal/10', className]}>
  <iframe
    title={`Map to ${site.name}`}
    src={mapEmbedUrl()}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="h-full w-full"
    style="border:0; min-height: 20rem;"></iframe>
</div>
