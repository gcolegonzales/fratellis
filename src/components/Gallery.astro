---
import { withBase } from '../lib/base';

export interface GalleryImage {
  src: string; // path under /public
  alt: string;
}
interface Props {
  images: GalleryImage[];
}
const { images } = Astro.props;
---

<ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
  {
    images.map((img, i) => (
      <li class={i % 5 === 0 ? 'sm:col-span-2 sm:row-span-2' : ''}>
        <a
          href={withBase(img.src)}
          class="gallery-item group block overflow-hidden rounded-card ring-1 ring-charcoal/10"
          data-index={i}
          aria-label={`View larger: ${img.alt}`}
        >
          <img
            src={withBase(img.src)}
            alt={img.alt}
            loading="lazy"
            decoding="async"
            width="800"
            height="600"
            class="aspect-[4/3] h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </a>
      </li>
    ))
  }
</ul>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-charcoal/90 p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Photo viewer"
>
  <button id="lightbox-close" class="absolute right-4 top-4 rounded-pill bg-cream-50/10 p-2 text-cream-50 hover:bg-cream-50/20" aria-label="Close">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <button id="lightbox-prev" class="absolute left-2 rounded-pill bg-cream-50/10 p-3 text-cream-50 hover:bg-cream-50/20 sm:left-6" aria-label="Previous photo">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <figure class="max-h-full max-w-4xl">
    <img id="lightbox-img" src="" alt="" class="max-h-[80vh] w-auto rounded-card" />
    <figcaption id="lightbox-caption" class="mt-3 text-center text-cream-100"></figcaption>
  </figure>
  <button id="lightbox-next" class="absolute right-2 rounded-pill bg-cream-50/10 p-3 text-cream-50 hover:bg-cream-50/20 sm:right-6" aria-label="Next photo">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<script>
  const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('.gallery-item'));
  const box = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const caption = document.getElementById('lightbox-caption');
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let current = 0;
  let lastFocused: HTMLElement | null = null;

  function show(index: number) {
    if (!items.length) return;
    current = (index + items.length) % items.length;
    const el = items[current];
    const src = el.getAttribute('href') || '';
    const image = el.querySelector('img');
    if (img) {
      img.src = src;
      img.alt = image?.alt || '';
    }
    if (caption) caption.textContent = image?.alt || '';
  }

  function open(index: number) {
    if (!box) return;
    lastFocused = document.activeElement as HTMLElement;
    show(index);
    box.classList.remove('hidden');
    box.classList.add('flex');
    closeBtn?.focus();
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!box) return;
    box.classList.add('hidden');
    box.classList.remove('flex');
    document.body.style.overflow = '';
    lastFocused?.focus();
  }

  items.forEach((el, i) =>
    el.addEventListener('click', (e) => {
      e.preventDefault();
      open(i);
    }),
  );
  closeBtn?.addEventListener('click', close);
  prevBtn?.addEventListener('click', () => show(current - 1));
  nextBtn?.addEventListener('click', () => show(current + 1));
  box?.addEventListener('click', (e) => {
    if (e.target === box) close();
  });

  document.addEventListener('keydown', (e) => {
    if (box?.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(current - 1);
    else if (e.key === 'ArrowRight') show(current + 1);
    else if (e.key === 'Tab') {
      // simple focus trap across the control buttons
      const focusables = [closeBtn, prevBtn, nextBtn].filter(Boolean) as HTMLElement[];
      const idx = focusables.indexOf(document.activeElement as HTMLElement);
      e.preventDefault();
      const next = e.shiftKey ? idx - 1 : idx + 1;
      focusables[(next + focusables.length) % focusables.length]?.focus();
    }
  });
</script>
