---
import { getEntry } from 'astro:content';

interface Props {
  limit?: number;
  columns?: 1 | 2 | 3;
}
const { limit, columns = 3 } = Astro.props;

const entry = await getEntry('testimonials', 'reviews');
const all = entry.data.reviews;
const reviews = limit ? all.slice(0, limit) : all;

const colClass = { 1: '', 2: 'sm:grid-cols-2', 3: 'sm:grid-cols-2 lg:grid-cols-3' }[columns];
---

<ul class:list={['grid gap-5', colClass]}>
  {
    reviews.map((r) => (
      <li class="hover-lift flex flex-col rounded-card bg-cream-50 p-6 shadow-soft ring-1 ring-charcoal/5 hover:shadow-lift">
        <div class="text-gold-500" aria-hidden="true">★★★★★</div>
        <blockquote class="mt-3 flex-1 font-display text-lg leading-snug text-charcoal">
          “{r.quote}”
        </blockquote>
        <cite class="mt-4 font-body text-sm not-italic text-charcoal-muted">
          — {r.author}
          {r.source && <span> · {r.source}</span>}
        </cite>
      </li>
    ))
  }
</ul>
