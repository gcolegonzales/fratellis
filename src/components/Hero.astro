---
import Button from './Button.astro';
import OpenNowBadge from './OpenNowBadge.astro';
import { withBase } from '../lib/base';
import { site } from '../lib/site';
---

<section class="bg-gradient-to-br from-cream-100 via-cream-200 to-cream-300">
  <div class="mx-auto grid max-w-content items-center gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[1.05fr_1fr] lg:gap-16 lg:py-24">
    <!-- Text -->
    <div>
      <p class="eyebrow">Prairieville, Louisiana · Est. {site.established}</p>
      <h1 class="mt-4 font-display text-6xl font-bold leading-[0.98] tracking-tight text-charcoal sm:text-7xl">
        Hearty Italian,<br />
        <span class="text-terracotta-600">served like family.</span>
      </h1>
      <p class="mt-5 max-w-md text-lg font-medium leading-relaxed text-charcoal-light">
        A family-owned kitchen where the sauce simmers all day and everything's made by hand — big
        plates of pasta, wood-fired pizza, and Italian classics. No fuss, just good food.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Button href={withBase('/menu')} variant="primary" size="lg">See the menu</Button>
        <Button href={withBase('/reservations')} variant="secondary" size="lg">Reserve a table</Button>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-3">
        <OpenNowBadge />
        <a
          href={`tel:${site.phoneHref}`}
          class="text-sm font-semibold text-terracotta-700 no-underline hover:underline"
        >
          {site.phone}
        </a>
      </div>
    </div>

    <!-- Photo of the place -->
    <div class="relative">
      <img
        src={withBase('/images/hero.jpg')}
        alt="The cozy, wood-beamed dining room at Fratelli's"
        width="1200"
        height="1500"
        fetchpriority="high"
        class="aspect-[4/5] w-full rounded-card object-cover shadow-lift ring-1 ring-charcoal/10"
      />
      <!-- little grille badge -->
      <div
        class="absolute -bottom-4 -left-4 hidden rounded-card bg-terracotta-600 px-5 py-3 text-cream-50 shadow-lift sm:block"
      >
        <p class="font-display text-lg font-semibold leading-none">Family owned</p>
        <p class="mt-1 text-xs uppercase tracking-[0.18em] text-cream-100/85">Since {site.established}</p>
      </div>
    </div>
  </div>
</section>
