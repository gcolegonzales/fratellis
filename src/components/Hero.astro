---
import Button from './Button.astro';
import OpenNowBadge from './OpenNowBadge.astro';
import { withBase } from '../lib/base';
import { site } from '../lib/site';
---

<section class="relative isolate flex min-h-[78vh] items-center overflow-hidden bg-charcoal text-cream-100">
  <!-- Real photography + a warm scrim for a cozy, legible hero -->
  <img
    src={withBase('/images/hero.jpg')}
    alt=""
    aria-hidden="true"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-charcoal/90 via-charcoal/65 to-transparent"
  >
  </div>
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(130%_120%_at_10%_90%,theme(colors.terracotta.800/.6),transparent_62%)] mix-blend-multiply"
  >
  </div>

  <div class="mx-auto w-full max-w-content px-5 py-24 sm:px-8">
    <div class="max-w-2xl">
      <p class="flex items-center gap-3 font-body text-sm font-semibold uppercase tracking-[0.22em] text-gold-400">
        <span class="h-px w-10 bg-gold-400/70"></span>
        Prairieville, Louisiana · Est. {site.established}
      </p>
      <h1 class="mt-6 font-display text-5xl font-semibold leading-[1.02] text-cream-50 drop-shadow-sm sm:text-7xl">
        Hearty Italian,<br />
        <span class="italic text-cream-50">served like family.</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/85 sm:text-xl">
        A family-owned kitchen where the sauce simmers all day and everything's made by hand — big
        plates of pasta, wood-fired pizza, and Italian classics. No fuss, just good food.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <Button href={withBase('/reservations')} variant="primary" size="lg">Reserve a table</Button>
        <Button href={withBase('/menu')} size="lg" class="bg-cream-50/95 text-charcoal hover:bg-cream-50">
          Explore the menu
        </Button>
      </div>

      <div class="mt-9 flex flex-wrap items-center gap-x-5 gap-y-3">
        <OpenNowBadge />
        <a
          href={`tel:${site.phoneHref}`}
          class="text-sm font-semibold text-gold-300 no-underline transition-colors hover:text-gold-400"
        >
          {site.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- scroll cue -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-6 flex justify-center text-cream-100/50"
    aria-hidden="true"
  >
    <svg class="h-6 w-6 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M6 13l6 6 6-6" />
    </svg>
  </div>
</section>
