---
import { withBase, isActive } from '../lib/base';
import { site } from '../lib/site';

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Menu', href: '/menu' },
  { label: 'From the Bar', href: '/from-the-bar' },
  { label: 'Catering', href: '/catering' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-charcoal/10 bg-cream/90 backdrop-blur">
  <div class="mx-auto flex max-w-content items-center justify-between gap-4 px-5 py-3 sm:px-8">
    <a
      href={withBase('/')}
      class="font-display text-lg font-semibold leading-none text-charcoal no-underline sm:text-xl"
    >
      Fratelli's<span class="text-terracotta-600">.</span>
      <span class="block text-[0.65rem] font-body font-medium uppercase tracking-[0.2em] text-charcoal-muted"
        >Italian Grille</span
      >
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden items-center gap-6 lg:flex">
      {
        nav.map((item) => (
          <a
            href={withBase(item.href)}
            aria-current={isActive(item.href, current) ? 'page' : undefined}
            class:list={[
              'font-body text-sm font-medium text-charcoal-light no-underline transition-colors hover:text-terracotta-700',
              isActive(item.href, current) && 'text-terracotta-700',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={withBase('/reservations')}
        class="inline-flex items-center rounded-pill bg-terracotta-600 px-4 py-2 font-body text-sm font-semibold text-cream-50 no-underline shadow-soft transition-colors hover:bg-terracotta-700"
      >
        Reserve
      </a>
    </nav>

    <!-- Mobile controls -->
    <div class="flex items-center gap-2 lg:hidden">
      <a
        href={`tel:${site.phoneHref}`}
        aria-label={`Call ${site.name}`}
        class="rounded-pill p-2 text-terracotta-700 hover:bg-terracotta-50"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
        </svg>
      </a>
      <button
        id="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        class="inline-flex items-center gap-2 rounded-pill px-3 py-2 text-charcoal hover:bg-terracotta-50"
      >
        <span class="font-body text-sm font-semibold">Menu</span>
        <svg id="nav-icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg id="nav-icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav
    id="mobile-nav"
    aria-label="Primary"
    hidden
    class="border-t border-charcoal/10 bg-cream px-5 pb-6 pt-2 lg:hidden"
  >
    <ul class="flex flex-col">
      {
        nav.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href, current) ? 'page' : undefined}
              class:list={[
                'block border-b border-charcoal/5 py-3 font-body font-medium text-charcoal-light no-underline',
                isActive(item.href, current) && 'text-terracotta-700',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={withBase('/reservations')}
      class="mt-4 inline-flex w-full items-center justify-center rounded-pill bg-terracotta-600 px-4 py-3 font-body font-semibold text-cream-50 no-underline shadow-soft"
    >
      Reserve a Table
    </a>
  </nav>
</header>

<script>
  // Re-binds on every navigation (Astro View Transitions) via astro:page-load.
  function setOpen(open: boolean) {
    const toggle = document.getElementById('nav-toggle');
    const panel = document.getElementById('mobile-nav');
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', String(open));
    panel.hidden = !open;
    document.getElementById('nav-icon-open')?.classList.toggle('hidden', open);
    document.getElementById('nav-icon-close')?.classList.toggle('hidden', !open);
    if (open) panel.querySelector<HTMLAnchorElement>('a')?.focus();
  }

  function bindNav() {
    const toggle = document.getElementById('nav-toggle');
    if (!toggle) return;
    toggle.addEventListener('click', () =>
      setOpen(toggle.getAttribute('aria-expanded') !== 'true'),
    );
  }

  // Document/window listeners bound once (module runs once); they query live DOM.
  document.addEventListener('keydown', (e) => {
    const toggle = document.getElementById('nav-toggle');
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      toggle.focus();
    }
  });
  window.matchMedia('(min-width: 1024px)').addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });

  function setHeaderHeight() {
    const h = document.querySelector('header');
    if (h) document.documentElement.style.setProperty('--header-h', `${h.offsetHeight}px`);
  }
  window.addEventListener('resize', setHeaderHeight);

  document.addEventListener('astro:page-load', () => {
    bindNav();
    setHeaderHeight();
  });
</script>
