---
import { withBase } from '../lib/base';
import { site, formatAddress, directionsUrl } from '../lib/site';

const year = new Date().getFullYear();

const hoursSummary = [
  { label: 'Mon', value: 'Closed' },
  { label: 'Tue – Thu', value: '11 AM – 9 PM' },
  { label: 'Fri – Sat', value: '11 AM – 10 PM' },
  { label: 'Sun', value: '11 AM – 9 PM' },
];

const links = [
  { label: 'Menu', href: '/menu' },
  { label: 'From the Bar', href: '/from-the-bar' },
  { label: 'Reservations', href: '/reservations' },
  { label: 'Catering', href: '/catering' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-charcoal text-cream-100">
  <div class="mx-auto grid max-w-content gap-10 px-5 py-14 sm:px-8 md:grid-cols-3">
    <div>
      <p class="font-display text-2xl font-semibold text-cream-50">{site.name}</p>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-cream-100/80">{site.tagline}.</p>
      <address class="mt-4 not-italic text-sm leading-relaxed text-cream-100/80">
        {formatAddress()}<br />
        <a href={`tel:${site.phoneHref}`} class="text-gold-400 no-underline hover:underline"
          >{site.phone}</a
        >
      </address>
      <a
        href={directionsUrl()}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-block text-sm text-gold-400 no-underline hover:underline">Get directions →</a
      >
    </div>

    <div>
      <h2 class="font-body text-sm font-semibold uppercase tracking-[0.18em] text-gold-400">Hours</h2>
      <dl class="mt-4 space-y-1.5 text-sm text-cream-100/80">
        {
          hoursSummary.map((h) => (
            <div class="flex justify-between gap-6">
              <dt>{h.label}</dt>
              <dd>{h.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div>
      <h2 class="font-body text-sm font-semibold uppercase tracking-[0.18em] text-gold-400">Explore</h2>
      <ul class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
        {
          links.map((l) => (
            <li>
              <a href={withBase(l.href)} class="text-cream-100/80 no-underline hover:text-cream-50">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-cream-100/10">
    <div
      class="mx-auto flex max-w-content flex-col gap-1 px-5 py-5 text-xs text-cream-100/60 sm:flex-row sm:items-center sm:justify-between sm:px-8"
    >
      <p>© {year} {site.name}. Family owned since {site.established}.</p>
      <p>Prairieville, Louisiana</p>
    </div>
  </div>
</footer>
