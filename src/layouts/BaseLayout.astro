---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';
import RestaurantSchema from '../components/RestaurantSchema.astro';
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Authentic, made-to-order Italian in Prairieville, Louisiana. Family owned since 2017.',
  ogImage,
} = Astro.props;

const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — Authentic Italian in Prairieville, LA`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <Seo title={fullTitle} description={description} ogImage={ogImage} />
    <RestaurantSchema />
    <ViewTransitions />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only rounded-pill focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-terracotta-600 focus:px-4 focus:py-2 focus:text-cream-50"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-reveal (ADR 0003). Runs on initial load AND after every Astro
      // View Transitions navigation via the `astro:page-load` event.
      function initReveal() {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const targets = document.querySelectorAll('[data-reveal]:not(.is-visible)');
        if (reduce) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        document.documentElement.classList.add('reveal-active');
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        targets.forEach((el) => {
          // Elements already in view on load reveal immediately (no flash).
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.92) el.classList.add('is-visible');
          else io.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
